APP_ENV=local
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
DATABASE_URL=postgresql://platform:platform@postgres:5432/platform

# Security (dev-only defaults for local; set explicitly for any shared env)
JWT_SECRET=dev-local-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=7
# Required by API internal auth and Prometheus /metrics scrape auth.
INTERNAL_API_TOKEN=dev-local-internal-token
WORKER_AUTH_TOKENS={"worker-local":"dev-local-worker-token"}
WORKER_AUTH_TOKEN=dev-local-worker-token
FAKE_INTERNAL_SERVICE_TOKEN=dev-local-service-token
INPUT_ENCRYPTION_KEY=dev-local-input-encryption-key
APPROVAL_SIGNAL_DISPATCHER_ENABLED=true
APPROVAL_SIGNAL_DISPATCH_INTERVAL_S=2
APPROVAL_SIGNAL_DISPATCH_BATCH_SIZE=20
APPROVAL_SIGNAL_RETRY_BASE_DELAY_S=2
APPROVAL_SIGNAL_RETRY_MAX_DELAY_S=30
APPROVAL_SIGNAL_RETRY_MAX_ATTEMPTS=6
TEMPORAL_SIGNAL_FAIL_ONCE=false
RERUN_CONFLICT_TEST_MODE=false

# Tenant + Worker
TEMPORAL_TARGET=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=xh-task-queue
DEFAULT_TENANT_ID=default
DEFAULT_WORKER_ID=worker-local
ALLOWED_WORKER_IDS=["worker-local"]

# Service URLs
API_BASE_URL=http://localhost:18000
FAKE_INTERNAL_BASE_URL=http://fake-internal-service:8100
NEXT_PUBLIC_API_BASE_URL=http://localhost:18000
NEXT_PUBLIC_AUTH_STORAGE=memory
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_STARTUP_STRICT=false
LANGGRAPH_POSTGRES_DSN=postgresql://platform:platform@postgres:5432/platform
LANGGRAPH_CHECKPOINT_FAIL_FAST=false
ARTIFACT_DIR=./artifacts
DOCS_DIR=./data/docs
REDIS_URL=redis://redis:6379/0

# Qwen / DashScope (optional)
# Official OpenAI-compatible base URL for Alibaba Cloud Model Studio.
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TIMEOUT_S=60

# MAS (multi-agent system)
MAS_ENABLED=false
# closed_loop: LangGraph graph-native MAS orchestration (default); gate: legacy compatibility gate.
MAS_ORCHESTRATION_MODE=closed_loop
MAS_MESSAGE_BACKEND=memory
MAS_CACHE_TTL_S=120
MAS_RATE_LIMIT_REQUESTS=30
MAS_RATE_LIMIT_WINDOW_S=60
MAS_RETRY_MAX_ATTEMPTS=3
MAS_RETRY_BASE_DELAY_S=1
MAS_RETRY_MAX_DELAY_S=10
MAS_SHADOW_MODE=false

# Seed accounts
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=ChangeMe123!
SEED_OPERATOR_EMAIL=operator@example.com
SEED_OPERATOR_PASSWORD=ChangeMe123!
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=ChangeMe123!

# Demo helper (optional)
DEMO_BASE_URL=http://localhost:18000
DEMO_TENANT_ID=default
DEMO_USER_EMAIL=user@example.com
DEMO_USER_PASSWORD=ChangeMe123!
DEMO_OPERATOR_EMAIL=operator@example.com
DEMO_OPERATOR_PASSWORD=ChangeMe123!
